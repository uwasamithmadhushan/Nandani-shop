# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/nandani-shop

# Secret for JWT signing — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Allowed origin for the React app (Vite default)
FRONTEND_ORIGIN=http://localhost:5173

# Optional
# PORT=4000
